# Copy this file to .env and fill in your own values.
# NEVER commit the real .env file to git.

# MongoDB Atlas connection string
# Get this from MongoDB Atlas -> Database -> Connect -> Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/adhd_app?retryWrites=true&w=majority

# Port the Express server listens on
PORT=5001

# Secret used to sign auth tokens (use a long random string in production)
JWT_SECRET=replace-this-with-a-long-random-string

# Comma-separated list of allowed frontend origins for CORS
CORS_ORIGIN=http://localhost:5173
